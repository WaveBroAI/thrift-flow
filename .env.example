# ──────────────────────────────────────────────────────────────────────────────
# thrift-flow — environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Provider API keys ──────────────────────────────────────────────────────────
# thrift-flow holds all keys. Clients (crab-bot, wavehammer, ...) don't need them.
#
# Provider base URLs are handled automatically by LiteLLM — you do NOT need to
# configure them here:
#   openrouter/* models  →  https://openrouter.ai/api/v1   (auto)
#   groq/*       models  →  https://api.groq.com/openai/v1  (auto)
#   anthropic/*  models  →  https://api.anthropic.com       (auto)

OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...

# ── Proxy server (optional — overrides config.yaml) ───────────────────────────
# PROXY_HOST=0.0.0.0   # default: 0.0.0.0
# PROXY_PORT=8888       # default: 8888

# ── Logging (optional) ────────────────────────────────────────────────────────
# LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR

# ── Client connection (for reference — goes in the CLIENT's .env, not here) ───
# When connecting crab-bot or other agents to this proxy, set in their .env:
#   AI_MODEL=openai/cheap
#   OPENAI_API_BASE=http://localhost:8888/v1
