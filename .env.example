# ──────────────────────────────────────────────────────────────────────────────
# thrift-flow — environment variables
# Copy this file to .env and fill in your values.
#
# Provider URLs are handled automatically by LiteLLM — no base URLs needed here.
# Just set the API key for the provider(s) you use in config.yaml.
# ──────────────────────────────────────────────────────────────────────────────

# ── Provider API keys ──────────────────────────────────────────────────────────
# Only fill in the keys for providers you actually use.
# Model name prefix in config.yaml determines which key is used.

# OpenRouter  (prefix: openrouter/...)  https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Groq        (prefix: groq/...)        https://console.groq.com
# GROQ_API_KEY=gsk_...

# Anthropic   (prefix: anthropic/...)   https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI      (prefix: openai/...)      https://platform.openai.com
# OPENAI_API_KEY=sk-...

# Google      (prefix: gemini/...)      https://aistudio.google.com
# GEMINI_API_KEY=...

# Together AI (prefix: together_ai/...) https://api.together.xyz
# TOGETHERAI_API_KEY=...

# ── Proxy server (optional — overrides config.yaml) ───────────────────────────
# PROXY_HOST=0.0.0.0   # default: 0.0.0.0
# PROXY_PORT=8888       # default: 8888

# ── Logging (optional) ────────────────────────────────────────────────────────
# LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR

# ── Client connection (for reference — goes in the CLIENT's .env, not here) ───
# When connecting crab-bot or other agents to this proxy, set in their .env:
#   AI_MODEL=openai/cheap
#   OPENAI_API_BASE=http://localhost:8888/v1
